<Page x:Class="BlueWave.Views.Commande"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- FORMULAIRE -->
		<Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
			<StackPanel>

				<TextBlock Text="Gestion des Commandes"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="2*"/>
						<ColumnDefinition Width="2*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- CLIENT -->
					<ComboBox Grid.Column="0"
                              Margin="5"
                              Height="35"
                              ItemsSource="{Binding Clients}"
                              DisplayMemberPath="NomClient"
                              SelectedItem="{Binding SelectedClient}" />

					<!-- DESTINATION -->
					<TextBox Grid.Column="1"
                             Margin="5"
                             Height="35"
                             VerticalContentAlignment="Center"
                             Text="{Binding Destination}" />

					<!-- BOUTONS -->
					<StackPanel Grid.Column="2" Orientation="Horizontal">
						<Button Content="Ajouter"
                                Margin="5"
                                Padding="15,5"
                                Command="{Binding AddCommand}" />
					</StackPanel>

				</Grid>

			</StackPanel>
		</Border>

		<!-- TABLE -->
		<DataGrid Grid.Row="1"
                  ItemsSource="{Binding Commandes}"
                  AutoGenerateColumns="False">

			<DataGrid.Columns>
				<DataGridTextColumn Header="N°"
                                    Binding="{Binding NumeroCommande}"
                                    Width="80"/>

				<DataGridTextColumn Header="Client"
                                    Binding="{Binding Client.NomClient}"
                                    Width="*"/>

				<DataGridTextColumn Header="Destination"
                                    Binding="{Binding Destination}"
                                    Width="*"/>

				<DataGridTextColumn Header="Date"
                                    Binding="{Binding DateCommande}"
                                    Width="*"/>

				<!-- DELETE BUTTON -->
				<DataGridTemplateColumn Header="Action">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<Button Content="Supprimer"
                                    Command="{Binding DataContext.DeleteCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Padding="10,3"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

			</DataGrid.Columns>

		</DataGrid>

	</Grid>
</Page>