<Page x:Class="BlueWave.Views.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

<Grid Grid.Column="3" Margin="20,20,20,20" Grid.ColumnSpan="2" Grid.RowSpan="2">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel>
        <TextBlock Text="Tableau de bord" FontSize="24" FontWeight="Bold"/>
    </StackPanel>
    <UniformGrid Grid.Row="1" Columns="4" Margin="0,20,0,20">

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Export en cours (commande)"/>
                    <TextBlock Text="{Binding ExportEnCours}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Total Commandes"/>
                    <TextBlock Text="{Binding TotalCommandes}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Total Clients"/>
                    <TextBlock Text="{Binding TotalClients}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Total Fournisseurs"/>
                    <TextBlock Text="{Binding TotalFournisseurs}" FontSize="22" FontWeight="Bold"/>
            </StackPanel>
        </Border>

    </UniformGrid>

    <DataGrid Grid.Row="2"
              AutoGenerateColumns="False"
              HeadersVisibility="Column"
              CanUserAddRows="False"
              ItemsSource="{Binding Commandes}">

        <DataGrid.Columns>
            <DataGridTextColumn Header="N° commande" Binding="{Binding NumeroCommande}"/>
            <DataGridTextColumn Header="Date" Binding="{Binding DateCommande}"/>
            <DataGridTextColumn Header="Client" Binding="{Binding Client.NomClient}"/>
            <DataGridTextColumn Header="Produit" Binding="{Binding Produit.NomProduit}"/>
            <DataGridTextColumn Header="Quantité" Binding="{Binding Quantite}"/>                <DataGridTextColumn Header="Destination" Binding="{Binding Destination}"/>
            <DataGridTextColumn Header="Délai" Binding="{Binding Delai}"/>
            <DataGridTextColumn Header="Statut" Binding="{Binding Statut}"/>
        </DataGrid.Columns>

    </DataGrid>

</Grid>

</Page>