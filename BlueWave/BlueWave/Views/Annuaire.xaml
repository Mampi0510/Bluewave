<Page x:Class="BlueWave.Views.Annuaire"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      KeepAlive="True">

	<Grid Margin="30,25">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Margin="0,0,0,20">
			<TextBlock Text="Annuaire (CRM)" FontSize="24"
                       FontWeight="Bold" Foreground="#0D2137"/>
			<TextBlock Text="Gestion des clients et fournisseurs"
                       Foreground="#607D8B" FontSize="13" Margin="0,4,0,0"/>
		</StackPanel>

		<TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
			<TabControl.Resources>
				<Style TargetType="TabItem">
					<Setter Property="Padding" Value="20,10"/>
					<Setter Property="FontSize" Value="13"/>
				</Style>
			</TabControl.Resources>

			<!-- CLIENTS -->
			<TabItem Header="Clients">
				<Grid Margin="0,15,0,0">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
						<StackPanel>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition/>
									<ColumnDefinition/>
									<ColumnDefinition/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0" Margin="5">
									<TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding ClientVm.NomClient, UpdateSourceTrigger=PropertyChanged}"/>
									<TextBlock Text="Nom" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Collapsed"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding ClientVm.NomClient}" Value="">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding ClientVm.NomClient}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</Grid>

								<Grid Grid.Column="1" Margin="5">
									<TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding ClientVm.PrenomClient, UpdateSourceTrigger=PropertyChanged}"/>
									<TextBlock Text="Prénom" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Collapsed"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding ClientVm.PrenomClient}" Value="">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding ClientVm.PrenomClient}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</Grid>

								<Grid Grid.Column="2" Margin="5">
									<TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding ClientVm.Telephone, UpdateSourceTrigger=PropertyChanged}"/>
									<TextBlock Text="Téléphone" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Collapsed"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding ClientVm.Telephone}" Value="">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding ClientVm.Telephone}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</Grid>

								<Button Grid.Column="3" Content="+ Ajouter" Margin="5"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding ClientVm.AddCommand}"/>
							</Grid>
							<TextBlock Text="{Binding ClientVm.MErrorMessage}"
                                       Foreground="Red" Margin="5,5,0,0">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding ClientVm.MErrorMessage}" Value="{x:Null}">
												<Setter Property="Visibility" Value="Collapsed"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding ClientVm.MErrorMessage}" Value="">
												<Setter Property="Visibility" Value="Collapsed"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
						</StackPanel>
					</Border>

					<DataGrid Grid.Row="1"
                              Style="{StaticResource StyledDataGrid}"
                              ItemsSource="{Binding ClientVm.Clients}"
                              SelectedItem="{Binding ClientVm.SelectedClient}">
						<DataGrid.ColumnHeaderStyle>
							<Style TargetType="DataGridColumnHeader"
                                   BasedOn="{StaticResource StyledDataGridColumnHeader}"/>
						</DataGrid.ColumnHeaderStyle>
						<DataGrid.CellStyle>
							<Style TargetType="DataGridCell"
                                   BasedOn="{StaticResource StyledDataGridCell}"/>
						</DataGrid.CellStyle>
						<DataGrid.RowStyle>
							<Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource StyledDataGridRow}"/>
						</DataGrid.RowStyle>
						<DataGrid.Columns>
							<DataGridTextColumn Header="ID" Binding="{Binding RefClient}" Width="60"/>
							<DataGridTextColumn Header="Nom" Binding="{Binding NomClient}" Width="*"/>
							<DataGridTextColumn Header="Prénom" Binding="{Binding PrenomClient}" Width="*"/>
							<DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="*"/>
							<DataGridTemplateColumn Header="Action" Width="120">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Button Content="Supprimer"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Command="{Binding DataContext.ClientVm.DeleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>

			<!-- FOURNISSEURS -->
			<TabItem Header="Fournisseurs">
				<Grid Margin="0,15,0,0">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
						<StackPanel>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition/>
									<ColumnDefinition/>
									<ColumnDefinition/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0" Margin="5">
									<TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding FournisseurVm.NomFournisseur, UpdateSourceTrigger=PropertyChanged}"/>
									<TextBlock Text="Nom" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Collapsed"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding FournisseurVm.NomFournisseur}" Value="">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding FournisseurVm.NomFournisseur}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</Grid>

								<Grid Grid.Column="1" Margin="5">
									<TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding FournisseurVm.PrenomsFournisseur, UpdateSourceTrigger=PropertyChanged}"/>
									<TextBlock Text="Prénom" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Collapsed"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding FournisseurVm.PrenomsFournisseur}" Value="">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding FournisseurVm.PrenomsFournisseur}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</Grid>

								<Grid Grid.Column="2" Margin="5">
									<TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding FournisseurVm.TelephoneFournisseur, UpdateSourceTrigger=PropertyChanged}"/>
									<TextBlock Text="Téléphone" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Collapsed"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding FournisseurVm.TelephoneFournisseur}" Value="">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding FournisseurVm.TelephoneFournisseur}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</Grid>

								<Button Grid.Column="3" Content="+ Ajouter" Margin="5"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding FournisseurVm.AddCommand}"/>
							</Grid>
							<TextBlock Text="{Binding FournisseurVm.MErrorMessage}"
                                       Foreground="Red" Margin="5,5,0,0">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding FournisseurVm.MErrorMessage}" Value="{x:Null}">
												<Setter Property="Visibility" Value="Collapsed"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding FournisseurVm.MErrorMessage}" Value="">
												<Setter Property="Visibility" Value="Collapsed"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
						</StackPanel>
					</Border>

					<DataGrid Grid.Row="1"
                              Style="{StaticResource StyledDataGrid}"
                              ItemsSource="{Binding FournisseurVm.Fournisseurs}"
                              SelectedItem="{Binding FournisseurVm.SelectedFournisseur}">
						<DataGrid.ColumnHeaderStyle>
							<Style TargetType="DataGridColumnHeader"
                                   BasedOn="{StaticResource StyledDataGridColumnHeader}"/>
						</DataGrid.ColumnHeaderStyle>
						<DataGrid.CellStyle>
							<Style TargetType="DataGridCell"
                                   BasedOn="{StaticResource StyledDataGridCell}"/>
						</DataGrid.CellStyle>
						<DataGrid.RowStyle>
							<Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource StyledDataGridRow}"/>
						</DataGrid.RowStyle>
						<DataGrid.Columns>
							<DataGridTextColumn Header="ID" Binding="{Binding RefFournisseur}" Width="60"/>
							<DataGridTextColumn Header="Nom" Binding="{Binding NomFournisseur}" Width="*"/>
							<DataGridTextColumn Header="Prénom" Binding="{Binding PrenomsFournisseur}" Width="*"/>
							<DataGridTextColumn Header="Téléphone" Binding="{Binding TelephoneFournisseur}" Width="*"/>
							<DataGridTemplateColumn Header="Action" Width="120">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Button Content="Supprimer"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Command="{Binding DataContext.FournisseurVm.DeleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>
		</TabControl>
	</Grid>
</Page>