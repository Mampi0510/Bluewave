<Page x:Class="BlueWave.Views.Fournisseur"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORMULAIRE -->
        <Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
            <StackPanel>

                <TextBlock Text="Gestion des Fournisseurs"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Nom -->
                    <Grid Grid.Column="0" Margin="5">
                        <TextBox Height="35"
                 VerticalContentAlignment="Center"
                 Text="{Binding NomFournisseur, UpdateSourceTrigger=PropertyChanged}"
                 x:Name="TxtNom"/>
                        <TextBlock Text="Nom"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="5,0,0,0"
                   Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NomFournisseur}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NomFournisseur}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Prénom -->
                    <Grid Grid.Column="1" Margin="5">
                        <TextBox Height="35"
                 VerticalContentAlignment="Center"
                 Text="{Binding PrenomsFournisseur, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Prénom"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="5,0,0,0"
                   Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PrenomsFournisseur}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PrenomsFournisseur}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Téléphone -->
                    <Grid Grid.Column="2" Margin="5">
                        <TextBox Height="35"
                 VerticalContentAlignment="Center"
                 Text="{Binding TelephoneFournisseur, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Téléphone"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="5,0,0,0"
                   Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TelephoneFournisseur}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TelephoneFournisseur}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="Ajouter"
                                Margin="5"
                                Padding="15,5"
                                Command="{Binding AddCommand}"/>

                        <Button Content="Supprimer"
                                Margin="5"
                                Padding="15,5"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>

        <!-- TABLE -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Fournisseurs}"
                  SelectedItem="{Binding SelectedFournisseur}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RefFournisseur}" Width="80"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding NomFournisseur}" Width="*"/>
                <DataGridTextColumn Header="Prénom" Binding="{Binding PrenomsFournisseur}" Width="*"/>
                <DataGridTextColumn Header="Téléphone" Binding="{Binding TelephoneFournisseur}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Page>