<Page x:Class="BlueWave.Views.Client"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORMULAIRE -->
        <Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
            <StackPanel>

                <TextBlock Text="Gestion des Clients"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Margin="5"
                             Height="35"
                             VerticalContentAlignment="Center"
                             Text="{Binding NomClient, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="1"
                             Margin="5"
                             Height="35"
                             VerticalContentAlignment="Center"
                             Text="{Binding PrenomClient}" />

                    <TextBox Grid.Column="2"
                             Margin="5"
                             Height="35"
                             VerticalContentAlignment="Center"
                             Text="{Binding Telephone}" />

                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="Ajouter"
                                Margin="5"
                                Padding="15,5"
                                Command="{Binding AddCommand}"/>

                        <Button Content="Supprimer"
                                Margin="5"
                                Padding="15,5"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>

        <!-- TABLE -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Clients}"
                  SelectedItem="{Binding SelectedClient}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RefClient}" Width="80"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding NomClient}" Width="*"/>
                <DataGridTextColumn Header="Prénom" Binding="{Binding PrenomClient}" Width="*"/>
                <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Page>