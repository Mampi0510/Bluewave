<Page x:Class="BlueWave.Views.CommandeHub"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      KeepAlive="True">

    <Grid>
        <TabControl>

            <!-- COMMANDE -->
            <TabItem Header="Commandes">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Gestion des Commandes" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" Margin="5" Height="35"
                                          ItemsSource="{Binding Clients}"
                                          DisplayMemberPath="NomClient"
                                          SelectedItem="{Binding SelectedClient}"/>

                                <ComboBox Grid.Column="1" Margin="5" Height="35"
                                          ItemsSource="{Binding Exports}"
                                          DisplayMemberPath="Statut"
                                          SelectedItem="{Binding SelectedExport}"/>

                                <Grid Grid.Column="2" Margin="5">
                                    <TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Destination" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Destination}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Destination}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Grid.Column="3" Content="Ajouter" Margin="5" Padding="15,5"
                                        Command="{Binding AddCommandeCommand}"/>
                            </Grid>
                            <TextBlock Text="{Binding CommandeErrorMessage}" Foreground="Red" Margin="5,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Commandes}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="N°" Binding="{Binding NumeroCommande}" Width="60"/>
                            <DataGridTextColumn Header="Client" Binding="{Binding Client.NomClient}" Width="*"/>
                            <DataGridTextColumn Header="Destination" Binding="{Binding Destination}" Width="*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateCommande, StringFormat=dd/MM/yyyy}" Width="*"/>
                            <DataGridTemplateColumn Header="Action">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Supprimer" Padding="10,3"
                                                Command="{Binding DataContext.DeleteCommandeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- EXPORT -->
            <TabItem Header="Exports">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Gestion des Exports" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="5">
                                    <TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding Delai, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Délai (jours)" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Delai}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Grid Grid.Column="1" Margin="5">
                                    <TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding Statut, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Statut" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Statut}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Statut}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Grid.Column="2" Content="Ajouter" Margin="5" Padding="15,5"
                                        Command="{Binding AddExportCommand}"/>
                            </Grid>
                            <TextBlock Text="{Binding ExportErrorMessage}" Foreground="Red" Margin="5,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Exports}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="N°" Binding="{Binding NumeroExport}" Width="60"/>
                            <DataGridTextColumn Header="Délai" Binding="{Binding Delai}" Width="*"/>
                            <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="*"/>
                            <DataGridTemplateColumn Header="Action">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Supprimer" Padding="10,3"
                                                Command="{Binding DataContext.DeleteExportCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ACHAT -->
            <TabItem Header="Achats">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Gestion des Achats" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" Margin="5" Height="35"
                                          ItemsSource="{Binding Produits}"
                                          DisplayMemberPath="NomProduit"
                                          SelectedItem="{Binding SelectedProduit}"/>

                                <ComboBox Grid.Column="1" Margin="5" Height="35"
                                          ItemsSource="{Binding Commandes}"
                                          DisplayMemberPath="NumeroCommande"
                                          SelectedItem="{Binding SelectedCommande}"/>

                                <Grid Grid.Column="2" Margin="5">
                                    <TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding Quantite, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Quantité" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Quantite}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Grid.Column="3" Content="Ajouter" Margin="5" Padding="15,5"
                                        Command="{Binding AddAchatCommand}"/>
                            </Grid>
                            <TextBlock Text="{Binding AchatErrorMessage}" Foreground="Red" Margin="5,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Achats}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdAchat}" Width="60"/>
                            <DataGridTextColumn Header="Produit" Binding="{Binding Produit.NomProduit}" Width="*"/>
                            <DataGridTextColumn Header="Commande" Binding="{Binding NumeroCommande}" Width="*"/>
                            <DataGridTextColumn Header="Quantité" Binding="{Binding Quantite}" Width="*"/>
                            <DataGridTemplateColumn Header="Action">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Supprimer" Padding="10,3"
                                                Command="{Binding DataContext.DeleteAchatCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- APPROVISIONNEMENT -->
            <TabItem Header="Approvisionnements">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Gestion des Approvisionnements" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" Margin="5" Height="35"
                                          ItemsSource="{Binding Fournisseurs}"
                                          DisplayMemberPath="NomFournisseur"
                                          SelectedItem="{Binding SelectedFournisseur}"/>

                                <ComboBox Grid.Column="1" Margin="5" Height="35"
                                          ItemsSource="{Binding Produits}"
                                          DisplayMemberPath="NomProduit"
                                          SelectedItem="{Binding SelectedProduitApp}"/>

                                <Grid Grid.Column="2" Margin="5">
                                    <TextBox Height="35" VerticalContentAlignment="Center"
                                             Text="{Binding Certificat, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Certificat" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Certificat}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Certificat}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Grid.Column="3" Content="Ajouter" Margin="5" Padding="15,5"
                                        Command="{Binding AddApprovisionnnementCommand}"/>
                            </Grid>
                            <TextBlock Text="{Binding AppErrorMessage}" Foreground="Red" Margin="5,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Approvisionnements}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdApp}" Width="60"/>
                            <DataGridTextColumn Header="Fournisseur" Binding="{Binding Fournisseur.NomFournisseur}" Width="*"/>
                            <DataGridTextColumn Header="Produit" Binding="{Binding Produit.NomProduit}" Width="*"/>
                            <DataGridTextColumn Header="Certificat" Binding="{Binding Certificat}" Width="*"/>
                            <DataGridTemplateColumn Header="Action">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Supprimer" Padding="10,3"
                                                Command="{Binding DataContext.DeleteApprovisionnnementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>