<Page x:Class="BlueWave.Views.Export"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      KeepAlive="True">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
			<StackPanel>

				<TextBlock Text="Gestion des Exports"
                           FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- Délai -->
					<Grid Grid.Column="0" Margin="5">
						<TextBox Height="35" VerticalContentAlignment="Center"
								 Text="{Binding Delai, UpdateSourceTrigger=PropertyChanged}"/>
						<TextBlock Text="Délai (jours)" IsHitTestVisible="False"
								   VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray">
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Visibility" Value="Collapsed"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding Delai}" Value="">
											<Setter Property="Visibility" Value="Visible"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding Delai}" Value="{x:Null}">
											<Setter Property="Visibility" Value="Visible"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
					</Grid>

					<!-- Statut -->
                    <ComboBox Grid.Column="1" Margin="5" Height="35"
						  ItemsSource="{Binding Statuts}"
						  SelectedItem="{Binding Statut}"/>

                    <!-- Boutons -->
					<StackPanel Grid.Column="2" Orientation="Horizontal">
						<Button Content="Ajouter" Margin="5" Padding="15,5"
                                Command="{Binding AddCommand}"/>
						<Button Content="Supprimer" Margin="5" Padding="15,5"
                                Command="{Binding DeleteCommand}"/>
					</StackPanel>

				</Grid>

				<!-- Message erreur -->
				<TextBlock Text="{Binding MErrorMessage}" Foreground="Red" Margin="5,5,0,0">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Visibility" Value="Collapsed"/>
							<Style.Triggers>
								<DataTrigger Binding="{Binding MErrorMessage}" Value="{x:Null}">
									<Setter Property="Visibility" Value="Collapsed"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding MErrorMessage}" Value="">
									<Setter Property="Visibility" Value="Collapsed"/>
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>

			</StackPanel>
		</Border>

		<DataGrid Grid.Row="1" ItemsSource="{Binding Exports}"
                  SelectedItem="{Binding SelectedExport}"
                  AutoGenerateColumns="False" IsReadOnly="True">
			<DataGrid.Columns>
				<DataGridTextColumn Header="N°"     Binding="{Binding NumeroExport}" Width="60"/>
				<DataGridTextColumn Header="Délai"  Binding="{Binding Delai}"        Width="*"/>
				<DataGridTextColumn Header="Statut" Binding="{Binding Statut}"       Width="*"/>
				<DataGridTemplateColumn Header="Action">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<Button Content="Supprimer" Padding="10,3"
                                    Command="{Binding DataContext.DeleteCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
			</DataGrid.Columns>
		</DataGrid>

	</Grid>
</Page>