<Page x:Class="BlueWave.Views.Produit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      KeepAlive="True">

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Produits" FontSize="24"
                       FontWeight="Bold" Foreground="#0D2137"/>
            <TextBlock Text="Gestion du catalogue produits"
                       Foreground="#607D8B" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nom -->
                        <Grid Grid.Column="0" Margin="5">
                            <TextBox Height="35" VerticalContentAlignment="Center"
                            Text="{Binding NomProduit, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Nom du produit" IsHitTestVisible="False"
                                VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NomProduit}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NomProduit}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Prix -->
                        <Grid Grid.Column="1" Margin="5">
                            <TextBox Height="35" VerticalContentAlignment="Center"
                            Text="{Binding Prix, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Prix" IsHitTestVisible="False"
                                VerticalAlignment="Center" Margin="8,0" Foreground="#9E9E9E">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Prix}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Statut -->
                        <CheckBox Grid.Column="2" Margin="10,0" VerticalAlignment="Center"
                            Content="Actif" IsChecked="{Binding Statut}"/>

                        <!-- Bouton -->
                        <Button Grid.Column="3" Content="+ Ajouter" Margin="5"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding AddCommand}"/>
                    </Grid>

                    <TextBlock Text="{Binding MErrorMessage}" Foreground="Red" Margin="5,5,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MErrorMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding MErrorMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="1"
                      Style="{StaticResource StyledDataGrid}"
                      ItemsSource="{Binding Produits}"
                      SelectedItem="{Binding SelectedProduit}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader"
                           BasedOn="{StaticResource StyledDataGridColumnHeader}"/>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell"
                           BasedOn="{StaticResource StyledDataGridCell}"/>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow"
                           BasedOn="{StaticResource StyledDataGridRow}"/>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding CodeProduit}" Width="60"/>
                    <DataGridTextColumn Header="Nom" Binding="{Binding NomProduit}" Width="*"/>
                    <DataGridTextColumn Header="Prix (Ar)" Binding="{Binding Prix}" Width="100"/>
                    <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Statut}" Width="60"/>
                    <DataGridTemplateColumn Header="Action" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Supprimer"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding DataContext.DeleteCommand,
                                  RelativeSource={RelativeSource AncestorType=Page}}"
                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>