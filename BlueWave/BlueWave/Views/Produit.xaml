<Page x:Class="BlueWave.Views.Produit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      KeepAlive="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORMULAIRE -->
        <Border Padding="15" Margin="0,0,0,15" Background="#FFF" CornerRadius="8">
            <StackPanel>

                <TextBlock Text="Gestion des Produits"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Nom -->
                    <Grid Grid.Column="0" Margin="5">
                        <TextBox Height="35"
                 VerticalContentAlignment="Center"
                 Text="{Binding NomProduit, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Nom du produit"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="5,0,0,0"
                   Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NomProduit}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NomProduit}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Stock -->
                    <ComboBox Grid.Column="1"
              Margin="5"
              Height="35"
              ItemsSource="{Binding Stocks}"
              DisplayMemberPath="Type"
              SelectedItem="{Binding SelectedStock}"/>

                    <!-- Quantité -->
                    <Grid Grid.Column="2" Margin="5">
                        <TextBox Height="35"
                 VerticalContentAlignment="Center"
                 Text="{Binding Quantite, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Quantité"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="5,0,0,0"
                   Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Date réception -->
                    <DatePicker Grid.Column="3"
                Margin="5"
                Height="35"
                SelectedDate="{Binding DateReception}"/>

                    <!-- Statut -->
                    <CheckBox Grid.Column="4"
              Margin="10,0"
              VerticalAlignment="Center"
              Content="Actif"
              IsChecked="{Binding Statut}"/>

                    <!-- Boutons -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button Content="Ajouter"
                Margin="5"
                Padding="15,5"
                Command="{Binding AddCommand}"/>
                    </StackPanel>

                </Grid>

                <!-- Message erreur -->
                <TextBlock Text="{Binding MErrorMessage}"
                           Foreground="Red"
                           Margin="5,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding MErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </Border>

        <!-- TABLE -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Produits}"
                  SelectedItem="{Binding SelectedProduit}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"             Binding="{Binding CodeProduit}"    Width="60"/>
                <DataGridTextColumn Header="Nom"            Binding="{Binding NomProduit}"     Width="*"/>
                <DataGridTextColumn Header="Quantité"       Binding="{Binding Quantite}"       Width="80"/>
                <DataGridTextColumn Header="Date réception" Binding="{Binding Date_reception, StringFormat=dd/MM/yyyy}" Width="130"/>
                <DataGridCheckBoxColumn Header="Actif"      Binding="{Binding Statut}"         Width="60"/>

                <!-- DELETE BUTTON -->
                <DataGridTemplateColumn Header="Action">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Supprimer"
                                    Command="{Binding DataContext.DeleteCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Padding="10,3"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Page>