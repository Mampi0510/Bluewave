<Window x:Class="BlueWave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BlueWave" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8" Icon="/icon.png">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Grid Background="#0D2137" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- LOGO -->
            <StackPanel Grid.Row="0" Margin="20,25,20,20">
                <TextBlock Text="BlueWave" Foreground="White"
                           FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Gestion Commerciale" Foreground="#4A6FA5"
                           FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- MENU -->
            <StackPanel Grid.Row="1">

                <TextBlock Text="GÉNÉRAL" Foreground="#37474F"
                           FontSize="10" FontWeight="Bold"
                           Margin="20,10,0,5"/>

                <Button Content="  Tableau de bord"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Dashboard_click"/>

                <TextBlock Text="OPÉRATIONS" Foreground="#37474F"
                           FontSize="10" FontWeight="Bold"
                           Margin="20,15,0,5"/>

                <Button Content="  Achats &amp; Appro"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="GestionCommerciale_click"/>

                <TextBlock Text="RESSOURCES" Foreground="#37474F"
                           FontSize="10" FontWeight="Bold"
                           Margin="20,15,0,5"/>

                <Button Content="  Produits"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Produit_click"/>

                <Button Content="  Gestion des Stocks"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Stock_click"/>

                <Button Content="  Annuaire (CRM)"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Annuaire_click"/>
            </StackPanel>

            <!-- USER — collé en bas -->
            <Border Grid.Row="2" Margin="12,0,12,15"
                    Background="#1A2F45" CornerRadius="10" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="36" Height="36" CornerRadius="18"
                            Background="#00B386" VerticalAlignment="Center">
                        <TextBlock Text="A" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="15"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Admin" Foreground="White"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Admin Logistique" Foreground="#4A6FA5"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- CONTENT -->
        <Frame x:Name="MainFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>